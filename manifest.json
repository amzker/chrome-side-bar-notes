{
  "manifest_version": 3,
  "name": "Sidebar Notes+",
  "version": "2.0",
  "description": "A sidebar notes panel with rich text editing, image support, password protection, smart links, and full export/import.",
  "permissions": [
    "storage",
    "sidePanel",
    "clipboardRead",
    "clipboardWrite",
    "activeTab",
    "scripting",
    "tabs",
    "downloads"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open Sidebar Notes+"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}